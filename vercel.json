{
  "functions": {
    "api/eclipse.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(index|mobile|dashboard).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
